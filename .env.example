APP_ENV=local
LOG_LEVEL=INFO
DATAOPS_MEMORY_DIR=memory/store
DEFAULT_APPROVER_ROLE=data_platform_reviewer
ALLOW_EXECUTION=false
AWS_REGION=us-east-1
RAW_BUCKET=s3://enterprise-data-platform-raw
