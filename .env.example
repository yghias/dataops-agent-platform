SNOWFLAKE_ACCOUNT=example_account
SNOWFLAKE_USER=svc_dataops_platform
SNOWFLAKE_PASSWORD=masked_password
SNOWFLAKE_DATABASE=PLATFORM
SNOWFLAKE_SCHEMA=PLATFORM
SNOWFLAKE_WAREHOUSE=TRANSFORM_WH
AIRFLOW_BASE_URL=https://airflow.example.internal
METADATA_CATALOG=OPENMETADATA
VECTOR_STORE=pgvector
LLM_PROVIDER=OpenAI
